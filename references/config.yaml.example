# sg-task 配置示例
#
# 实际路径：~/.claude/sg-task/config.yaml

project_root: /path/to/your-project-root

repositories:
  - name: 批发后端
    key: pf-backend
    type: backend
    path: /path/to/your-project-root/pf-backend

  - name: 批发手机前端
    key: senguo-pf-easy-mobile
    type: mobile
    path: /path/to/your-project-root/senguo-pf-easy-mobile

  - name: 产地手机前端
    key: pf-mproducer-supplier
    type: mobile
    path: /path/to/your-project-root/pf-mproducer-supplier

  - name: 批发PC端
    key: senguo-pf-manage-frontend
    type: pc
    path: /path/to/your-project-root/senguo-pf-manage-frontend

  - name: 商户后端
    key: senguo-merchantcenter-backend
    type: backend
    path: /path/to/your-project-root/senguo-merchantcenter-backend

auto_commit: true
auto_push: true

# `auto_commit` 表示在 sg-task 写入任务文档后立即尝试同步
# 不是后台定时器，也不会自动提交 AI 之外的手工改动
# 自动或手动同步都只应处理 `.tasks`

# 仓库类型：
# backend / pc / mobile / mini-program / native / other
#
# `name` 是业务显示名，`key` 通常取目录名并保持稳定
# `path` 通常写用户机器上的真实仓库绝对路径
